SERVICE_NAME=api-gateway
GATEWAY_PORT=5000
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

JWT_SECRET=replace_with_a_long_random_jwt_secret
JWT_ISSUER=zaykaa.user-service

USER_SERVICE_URL=http://127.0.0.1:5001
CHEF_SERVICE_URL=http://127.0.0.1:5003
BOOKING_SERVICE_URL=http://127.0.0.1:5004
ORDER_SERVICE_URL=http://127.0.0.1:5005
LEGACY_BACKEND_URL=http://127.0.0.1:5002

RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120
UPSTREAM_TIMEOUT_SECONDS=15
